{
  "name": "paybolt-dashboard-be",
  "private": true,
  "version": "1.0.0",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.12.2",
    "yarn": "^1.22.0"
  },
  "scripts": {
    "build": "rimraf dist && nest build",
    "format": "prettier --write \"src/**/*.ts\" !\"src/migrations/*\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint \"src/**/*.ts\" --ignore-pattern \"src/migrations/**\" --fix",
    "prettier:fix": "prettier --write \"src/**/*.+(md|js|ts)\"",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "mig:gen": "npm run typeorm -- migration:generate ./src/migrations/$npm_config_name -d ./src/config/migration.config.ts",
    "mig:run": "npm run typeorm -- -d ./src/config/migration.config.ts migration:run",
    "mig:revert": "npm run typeorm -- -d ./src/config/migration.config.ts migration:revert",
    "deploy:prod": "bash scripts/prod-deploy.sh",
    "deploy:staging": "bash scripts/staging-deploy.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write \"src/**/*.ts\" !\"src/migrations/*\"",
      "eslint \"src/**/*.ts\" --ignore-pattern \"src/migrations/**/*.ts\" --fix",
      "git add ."
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/client-ses": "^3.723.0",
    "@aws-sdk/client-sns": "^3.723.0",
    "@aws-sdk/s3-request-presigner": "^3.717.0",
    "@json2csv/plainjs": "^7.0.6",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.1",
    "@nestjs/platform-socket.io": "^10.3.10",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.3.10",
    "@types/hbs": "^4.0.5",
    "axios": "^1.7.3",
    "bcryptjs": "^2.4.3",
    "body-parser": "^2.2.0",
    "bull": "^4.16.5",
    "cache-manager": "^5.7.6",
    "cache-manager-redis-yet": "^5.1.5",
    "cheerio": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.6",
    "crypto": "^1.0.1",
    "csv-parser": "^3.2.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "handlebars": "^4.7.8",
    "hbs": "^4.2.0",
    "helmet": "^7.1.0",
    "lodash": "^4.17.21",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "pg": "^8.12.0",
    "puppeteer": "^23.11.1",
    "qrcode": "^1.5.4",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.1",
    "rimraf": "^5.0.5",
    "rxjs": "^7.8.1",
    "safe-stable-stringify": "^2.5.0",
    "socket.io": "^4.7.5",
    "typeorm": "^0.3.20",
    "ulid": "^2.3.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/eslintrc": "^3.0.2",
    "@eslint/js": "^9.1.1",
    "@nestjs/cli": "^10.3.1",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.2",
    "@swc/cli": "^0.3.9",
    "@swc/core": "^1.4.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cache-manager": "^4.0.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.13",
    "@types/node": "^20.11.16",
    "@types/qrcode": "^1.5.5",
    "@types/redis": "^4.0.11",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-typescript-sort-keys": "^3.2.0",
    "eslint-plugin-unused-imports": "^3.1.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.2.5",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
