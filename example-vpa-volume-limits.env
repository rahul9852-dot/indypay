# VPA Volume Limits Configuration Example
# Copy these variables to your .env file

# Basic VPA Configuration
UPI_ID=default@paybolt
UTKARSH_VPA_ROUTING_STRATEGY=adaptive

# Multiple VPAs with Volume Limits (20L = 20,00,000)
# Each VPA has a daily limit of 20L (20,00,000 rupees) and 5000 transactions
UTKARSH_VPAS=[
  {
    "vpa": "vpa1@paybolt",
    "priority": 1,
    "isActive": true,
    "description": "Primary VPA - 20L daily limit, 5000 transactions",
    "maxDailyAmount": 2000000,
    "maxDailyTransactions": 5000,
    "circuitBreakerThreshold": 3,
    "rateLimitPerMinute": 500
  },
  {
    "vpa": "vpa2@paybolt",
    "priority": 2,
    "isActive": true,
    "description": "Secondary VPA - 20L daily limit, 5000 transactions",
    "maxDailyAmount": 2000000,
    "maxDailyTransactions": 5000,
    "circuitBreakerThreshold": 5,
    "rateLimitPerMinute": 400
  },
  {
    "vpa": "vpa3@paybolt",
    "priority": 3,
    "isActive": true,
    "description": "Tertiary VPA - 20L daily limit, 5000 transactions",
    "maxDailyAmount": 2000000,
    "maxDailyTransactions": 5000,
    "circuitBreakerThreshold": 7,
    "rateLimitPerMinute": 300
  }
]

# Enhanced VPA Monitoring Configuration
VPA_MONITORING_ENABLED=true
VPA_HEALTH_CHECK_INTERVAL=60

# Alert thresholds (JSON format)
VPA_ALERT_THRESHOLDS={
  "healthScoreMin": 50,
  "failureRateMax": 0.1,
  "responseTimeMax": 5000,
  "circuitBreakerFailures": 5
}

# Rate Limiting Configuration
VPA_RATE_LIMITING_ENABLED=true
VPA_DEFAULT_RATE_LIMIT=1000

# Circuit Breaker Configuration
VPA_CIRCUIT_BREAKER_ENABLED=true
VPA_CIRCUIT_BREAKER_THRESHOLD=5
VPA_CIRCUIT_BREAKER_TIMEOUT=30000

# Available Routing Strategies:
# - round_robin: Simple round-robin distribution
# - load_balance: Based on amount thresholds
# - user_based: Specific VPA per user
# - amount_based: VPA selection based on transaction amount
# - priority_based: Always use highest priority VPA
# - health_based: Always use healthiest VPA
# - adaptive: Combines health, priority, and load (RECOMMENDED)

# Volume Limit Features:
# ✅ Daily amount limit: 20L per VPA
# ✅ Daily transaction count limit: 1000 per VPA
# ✅ Automatic limit checking before VPA selection
# ✅ Real-time volume tracking
# ✅ Percentage-based monitoring (80% warning threshold)
# ✅ Daily reset at midnight
# ✅ API endpoints to check volume status

# API Endpoints for Volume Monitoring:
# GET /api/v1/payments/vpa/volume-limits - Check volume limits status
# GET /api/v1/payments/vpa/stats - Get comprehensive VPA statistics
# GET /api/v1/payments/vpa/debug - Debug VPA service data

# Example Usage:
# 1. Set up VPAs with maxDailyAmount: 2000000 (20L)
# 2. System automatically tracks daily volume
# 3. When limit is reached, VPA is excluded from selection
# 4. Check limits via API endpoints
# 5. Daily reset happens automatically at midnight 