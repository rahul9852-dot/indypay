<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Redirecting to Payment Gateway...</title>
    <!-- Debug: Template data: {{{json this}}} -->
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
        }
        .container {
            background: white;
            padding: 3rem 2rem;
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            text-align: center;
            max-width: 400px;
            width: 100%;
        }
        .logo {
            width: 60px;
            height: 60px;
            margin: 0 auto 1.5rem;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .logo svg {
            width: 36px;
            height: 36px;
        }
        h1 {
            color: #1a202c;
            font-size: 24px;
            margin-bottom: 0.5rem;
            font-weight: 600;
        }
        .subtitle {
            color: #718096;
            font-size: 14px;
            margin-bottom: 2rem;
        }
        .spinner {
            width: 50px;
            height: 50px;
            margin: 2rem auto;
            border: 4px solid #e2e8f0;
            border-top: 4px solid #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .status-text {
            color: #4a5568;
            font-size: 14px;
            margin-top: 1rem;
        }
        .security-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 2rem;
            padding: 12px;
            background: #f7fafc;
            border-radius: 8px;
            font-size: 12px;
            color: #4a5568;
        }
        .security-badge svg {
            width: 16px;
            height: 16px;
            color: #48bb78;
        }
        .warning-text {
            color: #e53e3e;
            font-size: 12px;
            margin-top: 1rem;
            padding: 8px;
            background: #fff5f5;
            border-radius: 6px;
            border: 1px solid #feb2b2;
        }
        .proceed-button {
            margin-top: 2rem;
            padding: 14px 32px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }
        .proceed-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(102, 126, 234, 0.6);
        }
        .proceed-button:active {
            transform: translateY(0);
        }
        @media (max-width: 480px) {
            .container {
                padding: 2rem 1.5rem;
            }
            h1 {
                font-size: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo">
            <svg fill="white" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
        </div>

        <h1>Secure Payment</h1>
        <p class="subtitle">Processing your payment request</p>

        <div class="spinner" id="spinner"></div>

        <p class="status-text" id="statusText">Please wait while we redirect you to the payment gateway...</p>

        <button class="proceed-button" id="proceedButton" style="display: none;" onclick="submitForm()">
            Proceed to Payment
        </button>

        <div class="security-badge">
            <svg fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span>256-bit SSL Encrypted</span>
        </div>

        <p class="warning-text">
            ⚠️ Do not refresh or close this page
        </p>
    </div>

    <form id="geopayForm" method="post" action="{{data.action}}" style="display: none;">
        <input type="hidden" name="merchantId" value="{{data.merchantId}}">
        <input type="hidden" name="callbackUrl" value="{{data.callbackUrl}}">
        <input type="hidden" name="merchantTxnId" value="{{data.merchantTxnId}}">
        <input type="hidden" name="merchantTxnAmount" value="{{data.merchantTxnAmount}}">
        <input type="hidden" name="cctype" value="{{data.cctype}}">
        <input type="hidden" name="currency" value="{{data.currency}}">
        <input type="hidden" name="customerName" value="{{data.customerName}}">
        <input type="hidden" name="customerEmailId" value="{{data.customerEmailId}}">
        <input type="hidden" name="customerMobileNo" value="{{data.customerMobileNo}}">
        <input type="hidden" name="customerStreetAddress" value="{{data.customerStreetAddress}}">
        <input type="hidden" name="timestamp" value="{{data.timestamp}}">
        <input type="hidden" name="Signature" value="{{data.Signature}}">
    </form>

    <script>
        function submitForm() {
            console.log('Submitting form to payment gateway...');
            document.getElementById('geopayForm').submit();
        }

        // Auto-submit the form after a brief delay for better UX
        window.onload = function() {
            console.log('Page loaded, preparing payment redirect...');

            // After 1 second, show the manual button and hide spinner
            setTimeout(function() {
                console.log('Showing manual proceed button');
                document.getElementById('spinner').style.display = 'none';
                document.getElementById('statusText').textContent = 'Click below to proceed to payment';
                document.getElementById('proceedButton').style.display = 'block';

                // Auto-submit immediately after button shows (total 1.5 seconds)
                setTimeout(function() {
                    console.log('Auto-submitting form...');
                    submitForm();
                }, 500);
            }, 1000);
        };

        // Prevent back button and refresh
        history.pushState(null, null, location.href);
        window.onpopstate = function () {
            history.go(1);
        };
    </script>
</body>
</html>
